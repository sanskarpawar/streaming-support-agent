# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.2

# PostgreSQL (Pagila database)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pagila

# Langfuse (optional — leave blank to disable tracing)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com   # US region: https://us.cloud.langfuse.com

# App
APP_ENV=development
LOG_LEVEL=INFO
